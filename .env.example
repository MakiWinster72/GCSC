# =========================
# BDAI_SC 配置文件
# 把这个文件复制为 .env，然后修改对应的配置
# =========================

# --------------------
# 站点地址 (Site URLs)
# --------------------
# 前端站点地址
BDAI_SC_SITE_URL=http://localhost:5173

# 后端站点地址
BDAI_SC_BACKEND_URL=http://localhost:8080

# --------------------
# 前端 (Vite) 开发服务器配置
# --------------------
# 监听地址，0.0.0.0 表示允许外部访问
BDAI_SC_FRONTEND_HOST=0.0.0.0

# Vite 开发服务器端口
BDAI_SC_FRONTEND_PORT=5173

# --------------------
# 前端环境变量 (注入到前端 JS，可通过 import.meta.env 访问)
# --------------------
# 前端站点地址
VITE_SITE_URL=http://localhost:5173

# 后端端口（前端据此构造 API 请求）
VITE_BACKEND_PORT=8080

# API 基础地址，前端 axios 实例的 baseURL
VITE_API_BASE=http://localhost:8080

# --------------------
# 后端 (Spring Boot)
# --------------------
# Spring Boot 服务端口
BDAI_SC_BACKEND_PORT=8080

# --------------------
# 数据库 (MySQL) 连接配置
# --------------------
# 注意：& 是 MySQL URL 参数分隔符，复制时不要换行
BDAI_SC_DB_URL=jdbc:mysql://127.0.0.1:3306/bdai_sc?useUnicode=true &
characterEncoding=utf8 &
serverTimezone=Asia/Shanghai &
useSSL=false &
allowPublicKeyRetrieval=true

# 数据库用户名
BDAI_SC_DB_USER=bdai_sc

# 数据库密码
BDAI_SC_DB_PASSWORD=bdai_sc

# --------------------
# 安全配置 (Security)
# --------------------
# CORS 允许的前端 origins，多个用逗号分隔
BDAI_SC_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# JWT 签名密钥，生产环境务必更换为复杂随机字符串
BDAI_SC_JWT_SECRET=bdai_sc-student-center-jwt-secret-key-change-me-in-production

# JWT 令牌过期时间（分钟）
BDAI_SC_JWT_EXPIRES_MINUTES=120

# --------------------
# 文件上传配置
# --------------------
# 上传文件的存储目录，相对路径（相对于 backend/）或绝对路径
# 示例：./uploads（相对）、/var/www/bdai_sc/uploads（绝对）
BDAI_SC_UPLOAD_DIR=./uploads
